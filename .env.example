# OpenAI API Key for cocktail recommendations
# Get your key at https://platform.openai.com/api-keys
# Copy this file to .env and add your key:
#   cp .env.example .env

OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Optional: recommendation model and sampling (reduce repetitive picks)
# OPENAI_RECOMMENDATIONS_MODEL=gpt-5-mini-2025-08-07
# Higher temperature (e.g. 0.9–1.1) → more varied cocktail names; lower → more repetitive.
# OPENAI_RECOMMENDATIONS_TEMPERATURE=0.9
# Optional nucleus sampling (e.g. 0.95); omit to use model default.
# OPENAI_RECOMMENDATIONS_TOP_P=0.95
# Raise if JSON is truncated (reasoning models also count internal "thinking" tokens).
# OPENAI_RECOMMENDATIONS_MAX_COMPLETION_TOKENS=4096

# Append each successful recommendation (profile + GPT numeric ratings) to data/gpt_recommendation_log.jsonl
# Set to 0, false, or off to disable.
# GPT_RECOMMENDATION_LOG=1

# Optional: model for customer menu item detail modal (default: gpt-4o-mini)
# OPENAI_MENU_DETAIL_MODEL=gpt-4o-mini
